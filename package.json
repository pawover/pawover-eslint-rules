{
  "name": "@pawover/eslint-rules",
  "author": "pawover<pawover@outlook.com>",
  "description": "pawover's esLint rules",
  "license": "MIT",
  "type": "module",
  "version": "0.0.2",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.22.0"
  },
  "keywords": [
    "pawover",
    "pawover-eslint",
    "pawover-eslint-rules"
  ],
  "homepage": "https://github.com/pawover/pawover-eslint-rules#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/pawover/pawover-eslint-rules.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "pnpm clean:output && tsc -p tsconfig.build.json",
    "public": "pnpm build && npm publish --access public",
    "check": "pnpm check:types & pnpm check:eslint & pnpm check:format",
    "check:types": "tsc",
    "check:eslint": "pnpm build && pnpm eslint --fix \"**/*.{js,cjs,mjs,ts,cts,mts,jsx,tsx,vue}\"",
    "check:format": "prettier --write \"**/*.{html,json}\"",
    "check:pack": "attw --pack .",
    "clean": "pnpm clean:lib & pnpm clean:output",
    "clean:lib": "rimraf node_modules",
    "clean:output": "rimraf dist",
    "lib:up": "taze -I -r --exclude pnpm"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.2.0",
    "eslint-plugin-antfu": "^3.2.2",
    "eslint-plugin-import-lite": "^0.6.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "taze": "^19.11.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "@eslint-react/eslint-plugin": ">=4.2.3",
    "@stylistic/eslint-plugin": ">=5.10.0",
    "eslint": ">=10.0.3",
    "eslint-plugin-antfu": ">=3.2.2",
    "eslint-plugin-import-lite": ">=0.6.0",
    "eslint-plugin-react-hooks": ">=7.0.1",
    "eslint-plugin-simple-import-sort": ">=13.0.0",
    "eslint-plugin-vue": ">=10.8.0",
    "react": ">=19.2.0",
    "typescript": ">=5.9.3",
    "typescript-eslint": ">=8.57.0"
  },
  "peerDependenciesMeta": {
    "@eslint-react/eslint-plugin": {
      "optional": true
    },
    "@stylistic/eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-antfu": {
      "optional": true
    },
    "eslint-plugin-import-lite": {
      "optional": true
    },
    "eslint-plugin-simple-import-sort": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-vue": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "typescript-eslint": {
      "optional": true
    }
  }
}
